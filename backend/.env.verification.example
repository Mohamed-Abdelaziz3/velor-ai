# Copy to backend/.env only for an isolated verification environment. Never
# reuse this local database identity or commit the resulting file.
ENV=verification
DATABASE_URL=postgresql+psycopg://velor_verification:velor_verification@127.0.0.1:5432/velor_verification
REDIS_URL=redis://127.0.0.1:6379/0

# Generate two independent values at runtime; empty values fail closed.
JWT_SECRET=
NODE_INTERNAL_SECRET=
TRUST_PROXY_HEADERS=false
PUBLIC_WEB_CHAT_RESPONSE_ENGINE=v2
WHATSAPP_RESPONSE_ENGINE=v2
EXTERNAL_API_RESPONSE_ENGINE=v2
PUBLIC_CHAT_REPLY_TIMEOUT_SECONDS=40
VELOR_PROVIDER_TIMEOUT_SECONDS=15
# The fallback/provider-stub load rehearsal intentionally raises the tenant cap.
PUBLIC_CHAT_SESSION_IP_LIMIT_PER_MINUTE=40
PUBLIC_CHAT_SESSION_TENANT_LIMIT_PER_MINUTE=40
PUBLIC_CHAT_IP_LIMIT_PER_MINUTE=400
PUBLIC_CHAT_VISITOR_LIMIT_PER_MINUTE=20
PUBLIC_CHAT_TENANT_LIMIT_PER_MINUTE=400
ENABLE_LEGACY_INTELLIGENCE_WORKER=false
ENABLE_META_WEBHOOK=false
# Leave GROQ_API_KEY unset for deterministic load and fallback certification.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
REQUIRE_AI_PROVIDER_READY=false
ALLOWED_ORIGINS=http://127.0.0.1
ALLOWED_HOSTS=127.0.0.1,localhost,testserver
COOKIE_SAMESITE=lax
MODEL_INPUT_COST_PER_1M=0
MODEL_OUTPUT_COST_PER_1M=0
ALLOW_SYNTHETIC_DEMO_SEED=0
VELOR_META_VERIFY_TOKEN=
META_APP_SECRET=
META_GRAPH_API_TOKEN=
META_PHONE_NUMBER_ID=
META_COMPANY_ID=
