# Copy to backend/.env. Never commit the resulting file.
# Local development defaults; production must use managed PostgreSQL, HTTPS,
# unique secrets, and an explicit allowlist.
ENV=development
PORT=8000
DATABASE_URL=sqlite:///velor_local.db
REDIS_URL=redis://127.0.0.1:6379/0

# Required. Generate unique values, for example with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
NODE_INTERNAL_SECRET=
TERMS_VERSION=2026-07-15
PRIVACY_VERSION=2026-07-15

ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
ALLOWED_HOSTS=127.0.0.1,localhost
TRUST_PROXY_HEADERS=false
GLOBAL_RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_LOCAL_MAX_ENTRIES=10000
RATE_LIMIT_REDIS_RETRY_SECONDS=30
VELOR_DB_WORKER_LIMIT=20
SQLITE_POOL_SIZE=32
SQLITE_MAX_OVERFLOW=16
SQLITE_POOL_TIMEOUT=30

# AI provider. An empty key keeps the bounded local fallback available and
# should make readiness report a degraded provider state.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=300
VELOR_PROVIDER_TIMEOUT_SECONDS=15
VELOR_WRITER_TEMPERATURE=0.35
VELOR_WRITER_MAX_TOKENS=500
PUBLIC_WEB_CHAT_RESPONSE_ENGINE=v2
PUBLIC_CHAT_REPLY_TIMEOUT_SECONDS=40
WHATSAPP_RESPONSE_ENGINE=v2
WHATSAPP_REPLY_TIMEOUT_SECONDS=40
# The external API uses V2 by default. V1 exists only as an explicit,
# non-release rollback while clients migrate to the external_message_id contract.
EXTERNAL_API_RESPONSE_ENGINE=v2
REQUIRE_AI_PROVIDER_READY=false

# Public Web Chat protection.
PUBLIC_CHAT_SESSION_IP_LIMIT_PER_MINUTE=10
PUBLIC_CHAT_SESSION_TENANT_LIMIT_PER_MINUTE=30
PUBLIC_CHAT_HARD_SESSION_CAP_PER_MONTH=10000
PUBLIC_CHAT_IP_LIMIT_PER_MINUTE=20
PUBLIC_CHAT_VISITOR_LIMIT_PER_MINUTE=10
PUBLIC_CHAT_TENANT_LIMIT_PER_MINUTE=60

# Knowledge and catalog upload limits.
KNOWLEDGE_UPLOAD_MAX_BYTES=5242880
KNOWLEDGE_EXTRACTED_MAX_CHARS=250000
KNOWLEDGE_COMPILED_MAX_CHARS=500000
KNOWLEDGE_ARCHIVE_MAX_UNCOMPRESSED_BYTES=20971520
KNOWLEDGE_PDF_MAX_PAGES=200
CATALOG_UPLOAD_MAX_BYTES=5242880
CATALOG_XLSX_MAX_UNCOMPRESSED_BYTES=20971520
COMPANY_SYSTEM_PROMPT_MAX_CHARS=3000

# Optional accounting rates. Keep at zero until verified provider pricing is
# configured; these are not merchant revenue figures.
MODEL_INPUT_COST_PER_1M=0
MODEL_OUTPUT_COST_PER_1M=0

# Optional Google OAuth. Keep disabled in the frontend unless both sides are set.
GOOGLE_CLIENT_ID=

# Optional Google Sheets lead export. Disabled because it sends customer PII
# to an external processor; enable only after explicit merchant consent and a
# tenant-specific data-processing review.
ENABLE_GOOGLE_SHEETS_EXPORT=false

# Optional Node WhatsApp QR gateway (Beta).
NODE_PORT=3005
NODE_HOST=127.0.0.1
NODE_GATEWAY_URL=http://127.0.0.1:3005
BACKEND_CHAT_URL=http://127.0.0.1:8000/chat
ALLOWED_FRONTEND=http://127.0.0.1:5173,http://localhost:5173
AUTO_BOOT_SESSIONS=false
AUTO_BOOT_DELAY_MS=1500
WHATSAPP_SEND_TIMEOUT_MS=15000
LOG_LEVEL=warn

# Synthetic fixture seeding is fail-closed. Set to 1 only temporarily against
# an isolated development/verification database, then remove it.
ALLOW_SYNTHETIC_DEMO_SEED=0

# Official Meta webhook scaffold. Disabled until production credentials,
# verification, and operational review are complete.
ENABLE_META_WEBHOOK=false
VELOR_META_VERIFY_TOKEN=
META_APP_SECRET=
META_GRAPH_API_TOKEN=
META_PHONE_NUMBER_ID=
META_COMPANY_ID=
# Optional JSON mapping for multiple Meta phone-number IDs handled by the
# same system-user token, e.g. {"123456789":"merchant_company_id"}.
META_PHONE_COMPANY_MAP=
META_GRAPH_API_VERSION=v17.0
WEBHOOK_INBOX_STALE_SECONDS=180
WEBHOOK_INBOX_MAX_ATTEMPTS=8

# Legacy intelligence worker is advisory/manual only.
ENABLE_LEGACY_INTELLIGENCE_WORKER=false
