# Copy to frontend/.env. VITE_* values are embedded in the browser bundle, so
# never put private keys or server-side secrets here. Keep the hostname aligned
# with the URL used to open Vite (do not mix localhost and 127.0.0.1), otherwise
# SameSite authentication cookies will not be sent.
VITE_API_BASE=http://127.0.0.1:8000

# Google OAuth is off by default. Enable only after configuring the same client
# in the backend and restricting its authorized origins.
VITE_ENABLE_GOOGLE_AUTH=false
VITE_GOOGLE_CLIENT_ID=
